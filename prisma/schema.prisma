// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Analysis {
  id                String   @id @default(cuid())
  slug              String?  @unique
  title             String
  description       String
  category          String?  // Kategoriyi opsiyonel yapıyoruz
  sector            String?  // Sektörü geçici olarak opsiyonel yapıyoruz
  popular           Boolean  @default(false)
  standards         String?
  turnaroundTime    String?
  sampleRequirement String?
  price             String?  @default("İstek Üzerine")
  seoTitle          String?
  seoDescription    String?
  keywords          String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Sector {
  id    String @id @default(cuid())
  name  String @unique
}

model BlogPost {
  id         String   @id @default(cuid())
  slug       String   @unique
  title      String
  date       DateTime @default(now())
  author     String
  category   String
  excerpt    String
  content    String
  coverImage     String?
  featured       Boolean  @default(false)
  keywords       String?
  focusKeyword   String?
  seoDescription String?
  metaTitle      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  company   String?
  phone     String?
  role      String   @default("user") // "user" or "admin"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String
  response  String?
  quoteData Json?    // { items: [], vatRate: 20, notes: "" }
  status    String   @default("pending") // pending, sent, rejected, accepted
  createdAt DateTime @default(now())
  repliedAt DateTime?
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model Category {
  id    String @id @default(cuid())
  name  String @unique
  type  String @default("blog") // "blog" or "analysis"
}

model SiteSettings {
  id          String   @id @default("default")
  logo        String?
  favicon     String?
  title       String   @default("Laboratuvar Çözüm Merkezi")
  description String   @default("Profesyonel laboratuvar analiz ve danışmanlık hizmetleri.")
  keywords    String?  @default("laboratuvar, analiz, test, kozmetik, ilaç")
  updatedAt   DateTime @updatedAt
}
